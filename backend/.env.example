# Entity Vault Backend Configuration
# Copy this file to .env and fill in your values.

# Snowflake Account (use the account locator, e.g., "ABC12345")
SNOWFLAKE_ACCOUNT=your_account_locator
SNOWFLAKE_USER=your_username
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=ENTITY_VAULT_DB
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Authentication method: "password", "token_file", or "externalbrowser"
SNOWFLAKE_AUTH_METHOD=password

# For password auth:
SNOWFLAKE_PASSWORD=your_password

# For token_file auth (Programmatic Access Token stored in a file):
# SNOWFLAKE_AUTH_METHOD=token_file
# SNOWFLAKE_TOKEN_FILE=/path/to/your/token_file
